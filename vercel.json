{
  "version": 2,
  "name": "medigo-app",
  "buildCommand": "pnpm install && pnpm --filter @workspace/frontend run build",
  "outputDirectory": "frontend/static-build",
  "env": {
    "PNPM_HOME": "/root/.pnpm"
  },
  "installCommand": "pnpm install --frozen-lockfile",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
